# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Public HTTPS base URL that Twilio can reach, for example an ngrok URL.
PUBLIC_BASE_URL=

# OpenAI Realtime credentials
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Challenge guardrail. The app refuses to call any other number unless code is changed.
TARGET_NUMBER=+18054398008

# Runtime knobs
CALL_TIMEOUT_SECONDS=210
ARTIFACTS_DIR=artifacts
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
